{
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx"
  ],
  "exclude": ["./jupyter_ws_tunnel_example"],
  "compilerOptions": {
      "rootDir": "src",
      "target": "esnext",
      "module": "esnext",
      "moduleResolution": "bundler",
      "lib": ["ESNext", "DOM"],
      "jsx": "react-jsx",
      "declaration": true,
      "composite": true,
      "sourceMap": true,
      "strict": true,
      "esModuleInterop": true,
      "experimentalDecorators": true,
      "emitDeclarationOnly": true,
      "emitDecoratorMetadata": true,
      "isolatedModules": true,
      "plugins": [],
      "types": [],
  },
}